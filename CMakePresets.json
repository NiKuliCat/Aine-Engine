{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 26,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "vs2026-x64",
            "displayName": "VS2026 x64",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "installDir": "${sourceDir}/out/install/${presetName}",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "AINE_BUILD_EDITOR": "ON",
                "CMAKE_CXX_STANDARD": "23"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "vs2026-debug",
            "configurePreset": "vs2026-x64",
            "configuration": "Debug"
        },
        {
            "name": "vs2026-release",
            "configurePreset": "vs2026-x64",
            "configuration": "Release"
        }
    ]
}